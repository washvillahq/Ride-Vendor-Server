PORT=5000
NODE_ENV=development

# MongoDB Connection String (Required)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.exmple.mongodb.net/ridevendor?retryWrites=true&w=majority

# JSON Web Token Secret (Required)
JWT_SECRET=this-is-a-very-long-and-secure-jwt-secret-key-change-it-in-prod
JWT_EXPIRES_IN=90d
JWT_COOKIE_EXPIRES_IN=90

# Cloudinary Setup for Image Uploads (Required for /cars/:id/images)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Paystack Configuration (Required for Payments)
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key_here

# ─── CORS & Redirects ────────────────────────────
CLIENT_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173

